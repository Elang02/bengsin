{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(auth|garage|expenses|cities|presets|fuel-prices|health|docs|openapi.json)(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "/bengsin-frontend/$1"
    }
  ]
}
